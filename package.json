{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:portal && npm run build:duty-clock-pwa",
    "build:portal": "vite build",
    "build:duty-clock-pwa": "node scripts/build-duty-clock-pwa.mjs",
    "deploy:cloudflare": "npm run build && wrangler pages deploy dist --project-name bendigo-flying-club-portal --branch main",
    "cloudflare:status": "wrangler pages project list",
    "supabase:status": "supabase migration list",
    "supabase:push": "supabase db push",
    "supabase:functions:deploy": "supabase functions deploy --project-ref joarmzswpufrduectjse",
    "audit:migrations": "node scripts/audit-supabase-migrations.mjs",
    "check:vouchers": "node scripts/check-voucher-readiness.mjs",
    "smoke:vouchers": "node scripts/smoke-voucher-live.mjs",
    "test:vouchers": "npx --yes deno test --node-modules-dir=false supabase/functions/_shared/trialVoucherReadiness.test.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "mobile:install": "npm --prefix apps/duty-clock install",
    "mobile:start": "npm --prefix apps/duty-clock run start",
    "mobile:check": "npm --prefix apps/duty-clock run typecheck && npm --prefix apps/duty-clock exec expo-doctor"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.58.0",
    "@types/node": "^24.3.0",
    "@types/react-big-calendar": "^1.16.2",
    "@types/react-router-dom": "^5.3.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.344.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.8.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "wrangler": "^4.112.0"
  }
}
