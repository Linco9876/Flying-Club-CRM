{
  "expo": {
    "name": "BFC Duty Clock",
    "slug": "bendigo-flying-club-duty-clock",
    "version": "1.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "bfcdutyclock",
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "experiments": {
      "baseUrl": "/duty-clock/app"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "au.com.bendigoflyingclub.dutyclock",
      "buildNumber": "2",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is checked when you start duty so the club can identify whether you are on-site.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "au.com.bendigoflyingclub.dutyclock",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/monochrome-icon.png",
        "backgroundColor": "#0F4C81"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is checked when you start duty so the club can identify whether you are on-site."
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "clubTimeZone": "Australia/Sydney"
    }
  }
}
